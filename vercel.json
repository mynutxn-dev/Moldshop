{
    "version": 2,
    "installCommand": "npm install",
    "buildCommand": "cd client && npm install && CI=false npm run build",
    "outputDirectory": "client/build",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/index.js": {
            "maxDuration": 30,
            "includeFiles": "server/**"
        }
    }
}